# Copy this file to .env and fill in values for your local environment.
# .env is gitignored — never commit real secrets.

# 1. Database — required for the app to start (every page calls connectDB)
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>"

# 2. Auth — required to log in, sign up, or hit a protected route
NEXT_PUBLIC_DOMAIN="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# 3. Cloudinary — required to add or edit a product (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 4. Stripe — required for the checkout flow
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 5. Public URLs — inlined into the client bundle at build time (rebuild after changing)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SITE_URL=
